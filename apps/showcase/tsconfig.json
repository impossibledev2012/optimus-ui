{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": "./",
        "outDir": "./out-tsc/app",
        "types": ["node"],
        "strict": false,
        "paths": {
            "primeng/*": ["../../packages/primeng/src/*/public_api"],
            "@openng/optimus-ui-motion": ["../../packages/optimus-ui-motion/src/index"],
            "@openng/optimus-ui-styled": ["../../packages/optimus-ui-styled/src/index"],
            "@openng/optimus-ui-styles": ["../../packages/optimus-ui-styles/src/index"],
            "@openng/optimus-ui-styles/*": ["../../packages/optimus-ui-styles/src/*/index", "../../packages/optimus-ui-styles/src/*"],
            "@openng/optimus-ui-utils": ["../../packages/optimus-ui-utils/src/index"],
            "@openng/optimus-ui-utils/*": ["../../packages/optimus-ui-utils/src/*/index", "../../packages/optimus-ui-utils/src/*"],
            "@openng/optimus-ui-themes": ["../../packages/optimus-ui-themes/src/index"],
            "@openng/optimus-ui-themes/types": ["../../packages/optimus-ui-themes/types/index"],
            "@openng/optimus-ui-themes/types/*": ["../../packages/optimus-ui-themes/types/*/index"],
            "@openng/optimus-ui-themes/tokens": ["../../packages/optimus-ui-themes/tokens/index"],
            "@openng/optimus-ui-themes/*": ["../../packages/optimus-ui-themes/src/presets/*/index", "../../packages/optimus-ui-themes/src/presets/*"],
            "@/*": ["./*"]
        }
    },
    "include": ["../../packages/primeng/src/**/*.d.ts"],
    "exclude": ["node_modules", "**/node_modules", "**/dist", "**/*.spec.ts", "**/*.test.ts"],
    "files": ["app/main.ts", "server/main.server.ts", "server/server.ts", "app/polyfills.ts"],
    "angularCompilerOptions": {
        "enableI18nLegacyMessageIdFormat": false,
        "strictInjectionParameters": false,
        "strictInputAccessModifiers": false,
        "strictTemplates": false
    }
}
